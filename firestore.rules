rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null &&
        request.auth.token.email in [
          'michael711hebert@gmail.com',
          'littlebear8991@gmail.com',
          'jchebert2010@gmail.com',
          'hpfanatic009@gmail.com'
        ];
    }

    // Default deny
    match /{document=**} { allow read, write: if false; }

    // Full access for all whitelisted family members
    match /users/{userId}              { allow read, write: if isAllowed(); }
    match /users/{userId}/{sub=**}     { allow read, write: if isAllowed(); }
    match /tasks/{taskId}              { allow read, write: if isAllowed(); }
    match /events/{eventId}            { allow read, write: if isAllowed(); }
    match /mealPlans/{docId}           { allow read, write: if isAllowed(); }
    match /games/{gameId}              { allow read, write: if isAllowed(); }
    match /emergencies/{docId}         { allow read, write: if isAllowed(); }
    match /households/{uid}/{sub=**}   { allow read, write: if isAllowed(); }

    // Family messages: only the sender may delete their own message
    match /familyMessages/{familyCode}/messages/{messageId} {
      allow read, create: if isAllowed();
      allow delete:       if isAllowed() && request.auth.uid == resource.data.userId;
    }
  }
}
